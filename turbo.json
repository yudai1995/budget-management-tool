{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "format": {
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test:api": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "generate:openapi": {
      "dependsOn": ["^build"],
      "outputs": ["../../packages/api-spec/openapi.json"],
      "cache": false
    },
    "codegen": {
      "dependsOn": ["generate:openapi", "^build"],
      "outputs": ["src/schema.d.ts", "dist/schema.d.ts"],
      "cache": false
    }
  }
}
