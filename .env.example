DB_HOSTNAME=127.0.0.1
DB_PORT=3306
DB_NAME=budgetdb
DB_USER=Admin
DB_PASSWORD=password
TZ=Asia/Tokyo

# Prisma 接続 URL（pnpm gen:keys で自動生成。手動設定する場合は以下の形式で）
DATABASE_URL="mysql://Admin:password@127.0.0.1:3306/budgetdb"

# JWT RS256 認証キー（下記コマンドで生成: pnpm gen:keys）
# 改行を \n に置換してシングルラインで設定すること
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Next.js から公開鍵を参照するための変数（NEXT_PUBLIC_ でなくよい — サーバー専用）
# apps/web/.env.local にも同じ JWT_PUBLIC_KEY を設定すること
