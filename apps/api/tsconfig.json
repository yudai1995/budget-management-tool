{
    "compilerOptions": {
        "lib": ["es5", "es6"],
        "target": "es5",
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "./build",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@budget/common": ["../../packages/common/src/index.ts"],
            "@budget/common/*": ["../../packages/common/src/*"]
        }
    },
    "exclude": ["node_modules", "src/__tests__"]
}
