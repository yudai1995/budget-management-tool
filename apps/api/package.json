{
  "name": "@budget/api",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "wait-on tcp:${DB_HOSTNAME:-127.0.0.1}:${DB_PORT:-3306} && PORT=3001 ts-node --files src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "db:docs": "ts-node --files scripts/generate-dbml.ts",
    "db:share": "pnpm run db:docs && dbdocs build ../../docs/database/schema.dbml --public",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/infrastructure/persistence/data-source.ts",
    "migration:run": "ts-node --files scripts/run-migrations.ts",
    "migration:revert": "ts-node --files scripts/revert-migration.ts",
    "test:unit": "vitest run src/__tests__/unit",
    "test:api": "vitest run src/__tests__/e2e",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "generate:openapi": "ts-node --files scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@budget/common": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@hono/zod-validator": "^0.5.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "hono": "^4.7.11",
    "mysql2": "^3.12.0",
    "nodemon": "^3.1.9",
    "reflect-metadata": "^0.2.2",
    "typeorm": "0.3.20",
    "ulid": "^3.0.2",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@dbml/cli": "^6.6.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.19.37",
    "dbdocs": "1.1.0",
    "ts-node": "10.9.2",
    "typeorm-to-dbml": "0.1.1",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=20"
  }
}
